# ─────────────────────────────────────────────
# PUBLIC (NEXT_PUBLIC_ prefix – safe for client)
# ─────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ─────────────────────────────────────────────
# SERVER-ONLY (NEVER prefix with NEXT_PUBLIC_)
# These are the Firebase Admin SDK credentials
# ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
# Paste the full private key — keep the -----BEGIN/END----- markers.
# On Vercel, paste as-is. Locally, wrap in quotes and use \n for newlines.
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ─────────────────────────────────────────────
# NODE-RED INTEGRATION
# ─────────────────────────────────────────────
# Base URL of your Node-RED instance (Render / Railway / local)
NODE_RED_URL=http://localhost:1880
# Shared secret so Node-RED only accepts requests from this backend
NODE_RED_SECRET=change_me_to_a_long_random_string_32chars

# ─────────────────────────────────────────────
# APP SETTINGS
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Invite code length for team join links
INVITE_CODE_LENGTH=8
